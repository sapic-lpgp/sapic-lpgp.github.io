---
import { getCollection } from 'astro:content';
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title } = Astro.props;
const pageTitle = title ? `${title} — SAPIC` : 'SAPIC';

const path = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=Space+Grotesk:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css"
    />
  </head>
  <body>
    <header class="site-header">
      <nav class="nav-inner" aria-label="Main navigation">
        <a href="/" class="nav-logo">SAPIC</a>

        <button
          class="nav-toggle"
          id="nav-toggle"
          aria-label="Toggle navigation"
          aria-expanded="false"
          aria-controls="nav-links"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="2" y1="5" x2="18" y2="5" />
            <line x1="2" y1="10" x2="18" y2="10" />
            <line x1="2" y1="15" x2="18" y2="15" />
          </svg>
        </button>

        <ul class="nav-links" id="nav-links" role="list">
          <li class={path === '/' ? 'nav-active' : ''}>
            <a href="/">Home</a>
          </li>
          <li class={path.startsWith('/gallery') ? 'nav-active' : ''}>
            <a href="/gallery/">Gallery</a>
          </li>
          <li class={path.startsWith('/plasma-physics') ? 'nav-active' : ''}>
            <a href="/plasma-physics/">Plasma physics</a>
          </li>
          <li class={path.startsWith('/numerics') ? 'nav-active' : ''}>
            <a href="/numerics/">Numerics</a>
          </li>
        </ul>
      </nav>
    </header>

    <main>
      <div class="page-wrapper">
        <slot />
      </div>
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <span>SAPIC · Laboratoire des Gaz et des Plasmas</span>
        <span>
          <a href="https://www.lpgp.universite-paris-saclay.fr" target="_blank" rel="noopener noreferrer">LPGP webpage</a>
          &middot;
          <a href="https://github.com/sapic-lpgp/sapic-lpgp.github.io" target="_blank" rel="noopener noreferrer">GitHub</a>
        </span>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('nav-toggle') as HTMLButtonElement | null;
      const links = document.getElementById('nav-links') as HTMLElement | null;
      if (toggle && links) {
        toggle.addEventListener('click', () => {
          const open = links.classList.toggle('nav-open');
          toggle.setAttribute('aria-expanded', String(open));
        });
      }
    </script>
  </body>
</html>
